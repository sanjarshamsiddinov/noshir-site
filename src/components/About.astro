---
import translations from "../data/translations.json";
export interface Props { lang: "en" | "uz" }
const { lang } = Astro.props;
const t = translations.about;
---

<section id="about" class="py-24 md:py-32 bg-[color:var(--color-paper)]">
  <div class="container-site">
    <div class="max-w-3xl mx-auto">
      <p class="eyebrow" data-reveal>{t.eyebrow[lang]}</p>
      <hr class="divider-gold" />
      <h2
        class="font-serif font-bold leading-[1.15] mb-8"
        style="font-size: clamp(1.85rem, 3.8vw, 3rem);"
        data-reveal
        style:--reveal-delay="100ms"
      >
        {t.heading[lang]}
      </h2>
      <div class="space-y-5 text-[1.05rem] leading-[1.8] text-[color:var(--color-ink)]">
        <p data-reveal style="--reveal-delay: 150ms;">{t.paragraph_1[lang]}</p>
        {t.paragraph_2[lang] && <p data-reveal style="--reveal-delay: 200ms;">{t.paragraph_2[lang]}</p>}
      </div>
    </div>
  </div>
</section>
