---
import translations from "../data/translations.json";
export interface Props { lang: "en" | "uz" | "ru" }
const { lang } = Astro.props;
const t = translations.about;
const tFooter = translations.footer;
---

<section id="about" class="py-24 md:py-32 bg-[color:var(--color-paper)]">
  <div class="container-site">
    <div class="max-w-3xl mx-auto">
      <p class="eyebrow" data-reveal>{t.eyebrow[lang]}</p>
      <hr class="divider-gold" />
      <h2
        class="font-serif font-bold leading-[1.15] mb-8"
        style="font-size: clamp(1.85rem, 3.8vw, 3rem);"
        data-reveal
        style:--reveal-delay="100ms"
      >
        {t.heading[lang]}
      </h2>
      <div class="space-y-5 text-[1.05rem] leading-[1.8] text-[color:var(--color-ink)]">
        <p data-reveal style="--reveal-delay: 150ms;">{t.paragraph_1[lang]}</p>
        <p data-reveal style="--reveal-delay: 200ms;">{t.paragraph_2[lang]}</p>
        <p data-reveal style="--reveal-delay: 250ms;">{t.paragraph_3[lang]}</p>
      </div>

      <!-- Official registration credential -->
      <div class="mt-10" data-reveal style="--reveal-delay: 280ms;">
        <a
          href="/noshir-registration.pdf"
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-3 p-4 pr-5 rounded-lg border border-[color:var(--color-navy)]/15 bg-white hover:border-[color:var(--color-gold)] hover:shadow-[0_10px_24px_-12px_rgba(15,29,52,0.18)] transition-all"
        >
          <span class="w-10 h-10 shrink-0 rounded-md bg-[color:var(--color-gold)]/15 flex items-center justify-center text-[color:var(--color-gold)] group-hover:bg-[color:var(--color-gold)]/25 transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </span>
          <span class="flex-1">
            <span class="block text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-[color:var(--color-ink-muted)]">
              {tFooter.legal_reg_number[lang]}
            </span>
            <span class="block font-serif text-[1.02rem] text-[color:var(--color-navy)] group-hover:text-[color:var(--color-accent)] transition-colors">
              {tFooter.legal_cert_link[lang]}
            </span>
          </span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[color:var(--color-ink-muted)] group-hover:text-[color:var(--color-gold)] transition-colors" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      </div>

      <!-- Leadership -->
      <div class="mt-14 pt-10 border-t border-[color:var(--color-navy)]/10" data-reveal style="--reveal-delay: 300ms;">
        <h3 class="text-[0.72rem] font-semibold tracking-[0.2em] uppercase text-[color:var(--color-accent)] mb-6">
          {t.team_heading[lang]}
        </h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="p-5 rounded-lg border border-[color:var(--color-navy)]/10 bg-white">
            <p class="font-serif text-lg font-bold text-[color:var(--color-navy)]">
              {t.team_director_name[lang]}
            </p>
            <p class="text-sm text-[color:var(--color-ink-muted)] mt-0.5">
              {t.team_director_title[lang]}
            </p>
          </div>
          <div class="p-5 rounded-lg border border-[color:var(--color-navy)]/10 bg-white">
            <p class="font-serif text-lg font-bold text-[color:var(--color-navy)]">
              {t.team_rights_name[lang]}
            </p>
            <p class="text-sm text-[color:var(--color-ink-muted)] mt-0.5">
              {t.team_rights_title[lang]}
            </p>
            <p class="text-sm mt-2">
              <a href="mailto:rights@noshirbooks.uz" class="text-[color:var(--color-accent)] hover:text-[color:var(--color-navy)]">
                rights@noshirbooks.uz
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
