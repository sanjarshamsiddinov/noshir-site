---
import translations from "../data/translations.json";
export interface Props { lang: "en" | "uz" | "ru" }
const { lang } = Astro.props;
const t = translations;

const rightsHeading = lang === "en"
  ? "Rights & Permissions"
  : lang === "ru"
    ? "Права и разрешения"
    : "Huquqlar va ruxsatlar";
---

<footer class="bookshelf-bg pt-20 pb-10 text-[color:var(--color-paper)]">
  <div class="container-site relative z-10">
    <div class="grid md:grid-cols-12 gap-10 md:gap-8 pb-14 border-b border-[color:var(--color-paper)]/10">
      <!-- Brand -->
      <div class="md:col-span-4">
        <a href="#top" class="inline-block mb-5">
          <img src="/logo-nav.png" alt="Noshir Books" class="h-12 w-auto" />
        </a>
        <p class="text-[color:var(--color-paper)]/70 leading-relaxed max-w-md">
          {t.footer.tagline[lang]}
        </p>
      </div>

      <!-- Nav -->
      <div class="md:col-span-2">
        <h3 class="text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-[color:var(--color-gold)] mb-5">
          {t.footer.nav_heading[lang]}
        </h3>
        <ul class="space-y-3">
          <li><a href="#about" class="text-[color:var(--color-paper)]/75 hover:text-[color:var(--color-paper)] transition-colors">{t.nav.about[lang]}</a></li>
          <li><a href="#catalog" class="text-[color:var(--color-paper)]/75 hover:text-[color:var(--color-paper)] transition-colors">{t.nav.catalog[lang]}</a></li>
          <li><a href="#contact" class="text-[color:var(--color-paper)]/75 hover:text-[color:var(--color-paper)] transition-colors">{t.nav.contact[lang]}</a></li>
        </ul>
      </div>

      <!-- Rights & Permissions -->
      <div class="md:col-span-3">
        <h3 class="text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-[color:var(--color-gold)] mb-5">
          {rightsHeading}
        </h3>
        <ul class="space-y-2 text-[color:var(--color-paper)]/75">
          <li class="text-[color:var(--color-paper)] font-medium">
            {t.about.team_rights_name[lang]}
          </li>
          <li class="text-[0.88rem] text-[color:var(--color-paper)]/65">
            {t.about.team_rights_title[lang]}
          </li>
          <li class="pt-2">
            <a href="mailto:rights@noshirbooks.uz" class="hover:text-[color:var(--color-paper)] transition-colors">
              rights@noshirbooks.uz
            </a>
          </li>
          <li>
            <a href="mailto:sanjarshamsiddinow@gmail.com" class="hover:text-[color:var(--color-paper)] transition-colors">
              sanjarshamsiddinow@gmail.com
            </a>
          </li>
        </ul>
      </div>

      <!-- General Contact -->
      <div class="md:col-span-3">
        <h3 class="text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-[color:var(--color-gold)] mb-5">
          {t.footer.contact_heading[lang]}
        </h3>
        <ul class="space-y-3 text-[color:var(--color-paper)]/75">
          <li><a href="tel:+998909684747" class="hover:text-[color:var(--color-paper)] transition-colors">+998 90 968 47 47</a></li>
          <li class="text-[0.88rem] leading-relaxed">
            {t.contact.address_value[lang]}
          </li>
        </ul>
      </div>
    </div>

    <!-- Legal block -->
    <div class="py-8 border-b border-[color:var(--color-paper)]/10 grid gap-2 md:grid-cols-2 text-[0.82rem] text-[color:var(--color-paper)]/60">
      <ul class="space-y-1">
        <li>{t.footer.legal_company[lang]}</li>
        <li>{t.footer.legal_director[lang]}</li>
        <li>{t.footer.legal_reg_number[lang]}</li>
      </ul>
      <ul class="space-y-1 md:text-right">
        <li>{t.footer.legal_stir[lang]}</li>
        <li>{t.footer.legal_isbn[lang]}</li>
        <li>
          <a
            href="/noshir-registration.pdf"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 text-[color:var(--color-gold)] hover:text-[color:var(--color-gold-soft)] underline underline-offset-4 decoration-[color:var(--color-gold)]/50 hover:decoration-[color:var(--color-gold-soft)]"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="12" y1="18" x2="12" y2="12"></line>
              <polyline points="9 15 12 18 15 15"></polyline>
            </svg>
            <span>{t.footer.legal_cert_link[lang]}</span>
          </a>
        </li>
      </ul>
    </div>

    <div class="pt-6 text-[0.82rem] text-[color:var(--color-paper)]/60">
      <p>{t.footer.copyright[lang]}</p>
    </div>
  </div>
</footer>
