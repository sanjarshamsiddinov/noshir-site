---
import translations from "../data/translations.json";
export interface Props { lang: "en" | "uz" }
const { lang } = Astro.props;
const t = translations.rights;
---

<section id="rights" class="py-20 md:py-28 bg-[color:var(--color-cream)]">
  <div class="container-site">
    <div class="max-w-lg mx-auto" data-reveal>
      <div class="bookshelf-bg rounded-xl p-8 md:p-10 text-[color:var(--color-paper)] shadow-[0_30px_60px_-20px_rgba(15,29,52,0.35)]">
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-lg bg-[color:var(--color-gold)]/15 flex items-center justify-center mb-6" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A44C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <h2 class="font-serif text-2xl md:text-3xl font-bold mb-4 text-[color:var(--color-paper)]">
            {t.cta_heading[lang]}
          </h2>
          <p class="text-[color:var(--color-paper)]/80 leading-relaxed mb-8">
            {t.cta_text[lang]}
          </p>
          <a
            href="mailto:rights@noshir.uz?subject=Translation%20Rights%20Inquiry"
            class="btn btn-primary !bg-[color:var(--color-gold)] !border-[color:var(--color-gold)] !text-[color:var(--color-navy-deep)] hover:!bg-[color:var(--color-gold-soft)] w-full"
          >
            {t.cta_button[lang]}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <p class="text-center text-sm text-[color:var(--color-paper)]/60 mt-5">
            <a href="mailto:rights@noshir.uz" class="hover:text-[color:var(--color-gold-soft)] underline underline-offset-4">
              rights@noshir.uz
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
